# Service identity
MESS_SERVICE_NAME=CESSDA MESS
MESS_SERVICE_BASE_URL=https://mess.cessda.eu

# Source SKG-IF endpoint
MESS_SOURCE_ENDPOINT=https://skg-if-staging.cessda.eu/api/products
MESS_SOURCE_PID_FILTER=filter=identifiers.id:{pid}

# External APIs
SCHOLEXPLORER_API_URL=https://api-beta.scholexplorer.openaire.eu/v3/Links
OPENAIRE_API_URL=https://api.openaire.eu/graph/v2
OPENALEX_API_URL=https://api.openalex.org
OPENAIRE_ACCESS_TOKEN=your-openaire-oauth-token-here
OPENALEX_API_KEY=your-openalex-api-key-here

# Cache freshness
MESS_CACHE_TTL_HOURS=48

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=mess
POSTGRES_USER=mess
POSTGRES_PASSWORD=change-me-in-production

# SPARQL knowledge graph (QLever)
# Path inside the mess-api container where export_triples.py writes the N-Triples file.
SPARQL_EXPORT_PATH=/export/graph.nt
# Base URL of the QLever SPARQL server (only needed when QLever is running).
# QLever is started separately via docker-compose.qlever.yml after indexing.
SPARQL_QUERY_URL=http://qlever:7001

# Admin
MESS_ADMIN_KEY=change-me-in-production

# Logging
LOG_LEVEL=INFO
